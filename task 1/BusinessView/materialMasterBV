{
	"_id": ObjectId("699c47103b3f748c81996a93"),
	"businessView": "materialMasterBV",
	"collection": "MaterialMasterV2",
	"defaultSortSetting": {
		"sortField": "createdAt",
		"sortDirection": -1
	},
	"searchTermFields": [
		"materialName",
		"materialCode",
		"materialType",
		"plant",
		"storageLocation",
		"status"
	],
	"aggregation": [
		{
			"$match": {
				"materialId": {
					"$exists": true
				}
			}
		},
		{
			"$match": "{{searchTerm}}"
		},
		{
			"$facet": {
				"paginatedResults": [
					{
						"$sort": {
							"createdAt": -1
						}
					},
					{
						"$project": {
							"_id": 0,
							"materialId": 1,
							"materialCode": 1,
							"materialName": 1,
							"materialType": 1,
							"description": 1,
							"plant": 1,
							"storageLocation": 1,
							"status": 1,
							"createdAt": 1
						}
					},
					{
						"($)match": "{{componentSetting.rowFilter}}"
					},
					{
						"($)sort": {
							"{{componentSetting.matSortActive}}": "{{componentSetting.matSortDirection}}"
						}
					},
					{
						"($)skip": "{{componentSetting.page}}"
					},
					{
						"($)limit": "{{componentSetting.limit}}"
					}
				],
				"totalCount": [
					{
						"$count": "count"
					}
				]
			}
		}
	]
}