{
	"_id" : ObjectId("699ebe7daab69ae9caccaf34"),
	"businessView" : "MaterialDetailBV",
	"aggregation" : [
		{
			"($)match" : {
				"materialId" : "{{inputParams.materialId}}"
			}
		},
		{
			"($)facet" : {
				"paginatedResults" : [
					{
						"$project" : {
							"_id" : 0,
							"materialId" : "$materialId",
							"materialCode" : 1,
							"materialName" : "$materialName",
							"materialType" : 1,
							"plant" : 1,
							"storageLocation" : 1,
							"status" : 1,
							"deliveryNumber" : "$deliveryDetails.deliveryNumber",
							"deliveryDate" : "$deliveryDetails.deliveryDate",
							"shipto" : "$deliveryDetails.shipto",
							"shiptoDesc" : "$deliveryDetails.shiptoDesc",
							"material" : "$materialCode",
							"materialDesc" : "$materialName"
						}
					}
				],
				"totalCount" : [
					{
						"($)count" : "count"
					}
				]
			}
		}
	],
	"collection" : "MaterialMasterV2",
	"defaultSortSetting" : {
		"sortField" : "_id",
		"sortDirection" : 1
	},
	"searchTermFields" : [ ],
	"totalCount" : [
		{
			"($)count" : "count"
		}
	]
}