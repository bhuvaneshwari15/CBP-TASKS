{
	"_id" : ObjectId("69afc025271d2688d093207a"),
	"businessView" : "shopDetailBV",
	"aggregation" : [
		{
			"$match" : {
				
			}
		},
		{
			"$facet" : {
				"paginatedResults" : [
					{
						"$project" : {
							"_id" : 0,
							"ShopId" : "$shopId",
							"ShopName" : "$shopName",
							"OwnerName" : "$ownerName",
							"GSTNumber" : "$gstNumber",
							"contactNumber" : "$contactNumber",
							"emailId" : "$email",
							"Address" : {
								"$concat" : [
									{
										"$ifNull" : [ "$address.doorNo", "" ]
									},
									", ",
									{
										"$ifNull" : [ "$address.street", "" ]
									},
									", ",
									{
										"$ifNull" : [ "$address.area", "" ]
									},
									", ",
									{
										"$ifNull" : [ "$address.city", "" ]
									},
									", ",
									{
										"$ifNull" : [ "$address.state", "" ]
									},
									" - ",
									{
										"$ifNull" : [ "$address.pincode", "" ]
									},
									", ",
									{
										"$ifNull" : [ "$address.country", "" ]
									}
								]
							}
						}
					}
				],
				"totalCount" : [
					{
						"$count" : "count"
					}
				]
			}
		}
	],
	"collection" : "shopMaster",
	"defaultSortSetting" : {
		"sortField" : "_id",
		"sortDirection" : -1
	},
	"searchTermFields" : [ ],
	"totalCount" : [
		{
			"($)count" : "count"
		}
	]
}